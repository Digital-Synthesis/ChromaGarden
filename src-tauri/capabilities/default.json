{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:allow-save",
    "dialog:allow-ask",
    "fs:allow-read-dir",
    "fs:read-all",
    "fs:allow-write",
    "fs:write-all",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "run-installer",
          "cmd": "msiexec",
          "args": true
        }
      ]
    }
  ]
}